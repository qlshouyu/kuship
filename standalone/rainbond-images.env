# rainbond 业务镜像离线包的单一真相源
#
# 规则：
#   - RAINBOND_VERSION 控制由 chart 模板按 `Cluster.installVersion` 注入的镜像 tag
#     （rbd-api / rbd-chaos / rbd-mq / rbd-worker / rainbond / rainbond-operator）
#   - RAINBOND_IMAGES：chart 渲染产物覆盖的镜像列表（含固定 tag），business-images-package.sh
#     会用 helm template 渲染并与本列表 1:1 严格 diff，出现差集立即报错。chart 升级
#     新增 / 删除 / 改 tag 时需同步本文件。
#   - RAINBOND_EXTRA_IMAGES：chart 不渲染、但运行期由 operator/CRD 动态使用的镜像
#     （例如 hosts-job 用的 alpine:3）。这部分不参与 chart diff，但同样会被打入
#     rainbond-images-<arch>.tar.zst 离线包中。
#
# 升级 rainbond 业务版本只改 RAINBOND_VERSION 一处即可。
RAINBOND_VERSION=v6.7.1-release

RAINBOND_IMAGES="
registry.cn-hangzhou.aliyuncs.com/goodrain/local-path-provisioner:v0.0.30
registry.cn-hangzhou.aliyuncs.com/goodrain/minio:RELEASE.2023-10-24T04-42-36Z
registry.cn-hangzhou.aliyuncs.com/goodrain/apisix-ingress-controller:v1.8.3
registry.cn-hangzhou.aliyuncs.com/goodrain/apisix:3.9.1-debian-fix
registry.cn-hangzhou.aliyuncs.com/goodrain/registry:2.6.2
registry.cn-hangzhou.aliyuncs.com/goodrain/rbd-monitor:v2.20.0
registry.cn-hangzhou.aliyuncs.com/goodrain/rbd-db:8.0.19
registry.cn-hangzhou.aliyuncs.com/goodrain/rbd-mq:${RAINBOND_VERSION}
registry.cn-hangzhou.aliyuncs.com/goodrain/rbd-chaos:${RAINBOND_VERSION}
registry.cn-hangzhou.aliyuncs.com/goodrain/rbd-worker:${RAINBOND_VERSION}
registry.cn-hangzhou.aliyuncs.com/goodrain/rbd-api:${RAINBOND_VERSION}
registry.cn-hangzhou.aliyuncs.com/goodrain/rainbond:${RAINBOND_VERSION}
registry.cn-hangzhou.aliyuncs.com/goodrain/rainbond-operator:${RAINBOND_VERSION}
"

RAINBOND_EXTRA_IMAGES="
registry.cn-hangzhou.aliyuncs.com/goodrain/alpine:3
"
